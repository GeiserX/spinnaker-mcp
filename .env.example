# Spinnaker Gate connection details
GATE_URL=http://localhost:8084
GATE_TOKEN=
GATE_USER=
GATE_PASS=
GATE_CERT_FILE=
GATE_KEY_FILE=
GATE_INSECURE=false

# Transport: "stdio" for stdio, empty or unset for HTTP
TRANSPORT=

# HTTP transport port (only used when TRANSPORT is not stdio, default: 8085)
MCP_PORT=8085
