# Spinnaker Gate connection details
GATE_URL=http://localhost:8084
GATE_TOKEN=
GATE_USER=
GATE_PASS=
GATE_CERT_FILE=
GATE_KEY_FILE=
GATE_INSECURE=false

# Transport: "stdio" for stdio, empty or unset for HTTP
TRANSPORT=

# HTTP transport port (only used when TRANSPORT is not stdio, default: 8085)
MCP_PORT=8085

# HTTP bind address (default: 127.0.0.1)
MCP_BIND_ADDR=

# Comma-separated tool groups to enable (default: all)
# Valid groups: applications, pipelines, executions, strategies, infrastructure, tasks
# Meta-groups: all, readonly, mutating
TOOLSETS=
