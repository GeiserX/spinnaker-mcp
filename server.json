{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.GeiserX/spinnaker-mcp",
  "description": "MCP server bridging Spinnaker continuous delivery platform to LLMs for application, pipeline, and deployment management",
  "repository": {
    "url": "https://github.com/GeiserX/spinnaker-mcp",
    "source": "github"
  },
  "version": "0.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "spinnaker-mcp",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GATE_URL",
          "description": "Spinnaker Gate API URL (e.g. http://spin-gate:8084)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "GATE_TOKEN",
          "description": "Bearer token for Gate authentication",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "GATE_USER",
          "description": "Basic auth username (alternative to token)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "GATE_PASS",
          "description": "Basic auth password",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "drumsergio/spinnaker-mcp:v0.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GATE_URL",
          "description": "Spinnaker Gate API URL (e.g. http://spin-gate:8084)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "GATE_TOKEN",
          "description": "Bearer token for Gate authentication",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "GATE_USER",
          "description": "Basic auth username (alternative to token)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "GATE_PASS",
          "description": "Basic auth password",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
